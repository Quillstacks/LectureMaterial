# Claude Code
.claude/

# Markdown notes (Claude memory, design docs, drafts)
# README.md is the GitHub Pages source and stays tracked.
# Contributor-facing markdown is tracked so it shows up on GitHub.
*.md
!README.md
!CONTRIBUTING.md
!.github/**/*.md

# Per-chapter draft wrappers from tools/draft.sh
lecturenotes/*/draft.tex
lecturenotes/*/draft.pdf

# Per-chapter build wrappers from tools/build_chapter_pdfs.sh (transient, header says "do not commit")
lecturenotes/*/_ch_*.tex
lecturenotes/*/_ch_*.pdf

# LaTeX build artifacts
*.aux
*.bbl
*.bcf
*.blg
*.fdb_latexmk
*.fls
*.idx
*.ilg
*.ind
*.lof
*.log
*.lot
*.nav
*.out
*.run.xml
*.snm
*.synctex.gz
*.synctex(busy)
*.toc
*.vrb
*.xdv

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Editor files
.vscode/
.idea/
*.swp
*.swo
*~

# Solutions, exam keys, grading data, student submissions
# (pre-emptive: never expose these even if accidentally dropped into a chapter folder)
solutions/
*_solutions.tex
*_solutions.pdf
*_loesungen.tex
*_loesungen.pdf
grades*.csv
gradebook*
students*.csv

# Per-book exam workspaces. Active exams stay local; only old exams that should
# be published as "Altklausuren" get moved out of these directories and tracked
# explicitly.
lecturenotes/*/exams/
